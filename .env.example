# ---------------------------------------------------------------------------
# ChatOps connection (required)
# ---------------------------------------------------------------------------

# Base URL of your ChatOps instance (no trailing slash)
CHATOPS_URL=https://chatops.yourcompany.com

# Bearer token — Personal Access Token or Bot Token
# Generate in: Account Settings > Security > Personal Access Tokens
CHATOPS_TOKEN=your_token_here

# ---------------------------------------------------------------------------
# Logging (optional)
# ---------------------------------------------------------------------------
LOG_LEVEL=info
